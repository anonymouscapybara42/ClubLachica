---
---
<footer class="bg-stone-900 text-stone-300 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="mb-6">
          <div class="font-display text-3xl font-light tracking-widest text-white">CLUB</div>
          <div class="font-display text-lg font-light tracking-[0.4em] text-pink-300">LA CHICA</div>
        </div>
        <p class="text-sm text-stone-400 leading-relaxed max-w-xs">
          Curated fashion for the modern Filipina. Feminine, bold, and effortlessly chic.
        </p>
        <div class="flex gap-4 mt-6">
          <a href="#" class="w-9 h-9 rounded-full border border-stone-700 flex items-center justify-center hover:border-pink-400 hover:text-pink-400 transition-all duration-300" aria-label="Instagram">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full border border-stone-700 flex items-center justify-center hover:border-pink-400 hover:text-pink-400 transition-all duration-300" aria-label="TikTok">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full border border-stone-700 flex items-center justify-center hover:border-pink-400 hover:text-pink-400 transition-all duration-300" aria-label="Facebook">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full border border-stone-700 flex items-center justify-center hover:border-pink-400 hover:text-pink-400 transition-all duration-300" aria-label="Pinterest">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.03-2.83.19-.77 1.26-5.33 1.26-5.33s-.32-.64-.32-1.59c0-1.49.86-2.61 1.94-2.61.91 0 1.36.68 1.36 1.5 0 .92-.58 2.29-.89 3.56-.25 1.06.53 1.93 1.57 1.93 1.89 0 3.15-2.44 3.15-5.32 0-2.19-1.47-3.83-4.14-3.83-3.03 0-4.92 2.26-4.92 4.78 0 .87.26 1.48.66 1.95.19.22.21.31.14.57l-.24.94c-.08.31-.33.42-.61.3-1.67-.68-2.44-2.5-2.44-4.55 0-3.38 2.85-7.44 8.52-7.44 4.58 0 7.6 3.33 7.6 6.9 0 4.74-2.62 8.3-6.47 8.3-1.3 0-2.52-.7-2.94-1.49l-.82 3.17c-.26.97-.74 1.95-1.19 2.7.9.26 1.85.41 2.83.41 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-body font-semibold text-white text-sm tracking-widest uppercase mb-6">Explore</h4>
        <ul class="space-y-3">
          {['Home', 'About Us', 'Catalog', 'Collection', 'Contact Us'].map(item => (
            <li>
              <a 
                href={item === 'Home' ? '/' : `/${item.toLowerCase().replace(' ', '')}`}
                class="text-sm text-stone-400 hover:text-pink-300 transition-colors duration-300"
              >
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Customer Care -->
      <div>
        <h4 class="font-body font-semibold text-white text-sm tracking-widest uppercase mb-6">Customer Care</h4>
        <ul class="space-y-3">
          {['Size Guide', 'Shipping & Delivery', 'Returns & Exchanges', 'FAQs', 'Track My Order'].map(item => (
            <li>
              <a href="#" class="text-sm text-stone-400 hover:text-pink-300 transition-colors duration-300">{item}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-body font-semibold text-white text-sm tracking-widest uppercase mb-6">Contact Us</h4>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 text-pink-400 flex-shrink-0" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <p class="text-sm text-stone-400 leading-relaxed">Bacolod City, Philippines</p>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 text-pink-400 flex-shrink-0" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <p class="text-sm text-stone-400">hello@clublachica.ph</p>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 text-pink-400 flex-shrink-0" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.46 16"/>
            </svg>
            <p class="text-sm text-stone-400">+63 917 123 4567</p>
          </div>
        </div>

        <!-- Newsletter -->
        <div class="mt-6">
          <p class="text-sm font-semibold text-white mb-3">Stay in the loop</p>
          <div class="flex gap-2">
            <input 
              type="email" 
              placeholder="Your email" 
              class="flex-1 bg-stone-800 border border-stone-700 rounded-full px-4 py-2.5 text-sm text-stone-300 placeholder-stone-600 focus:outline-none focus:border-pink-400 transition-colors"
            />
            <button class="bg-pink-400 hover:bg-pink-500 text-white rounded-full px-4 py-2.5 text-sm font-medium transition-colors">
              Join
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-stone-600">© 2025 Club La Chica. All rights reserved.</p>
      <div class="flex gap-6">
        {['Privacy Policy', 'Terms & Conditions', 'Cookie Policy'].map(item => (
          <a href="#" class="text-xs text-stone-600 hover:text-stone-400 transition-colors">{item}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
