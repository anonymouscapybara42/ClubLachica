---
export interface Props {
  name: string;
  price: string;
  category?: string;
  images?: string[];      // array of image paths from /public
  imageSrc?: string;      // single image fallback
  badge?: string;
  index?: number;
}

const { name, price, category = 'Clothing', images = [], imageSrc, badge, index = 0 } = Astro.props;

// Build final image list: prefer images[] array, fall back to single imageSrc
const imgList = images.length > 0 ? images : (imageSrc ? [imageSrc] : []);
const primaryImg = imgList[0] ?? null;
const hoverImg = imgList[1] ?? null;

const gradients = [
  'from-pink-200 via-rose-100 to-champagne',
  'from-sage-200 via-green-100 to-cream',
  'from-pink-100 via-purple-50 to-rose-100',
  'from-amber-100 via-orange-50 to-pink-100',
  'from-sky-100 via-indigo-50 to-purple-100',
  'from-green-100 via-teal-50 to-cyan-100',
];
const gradient = gradients[index % gradients.length];
const cardId = `card-${index}-${name.replace(/\s+/g, '')}`;
---

<div class="product-card animate-on-scroll group" style={`transition-delay: ${index * 0.08}s`} id={cardId}>
  <!-- Image Container -->
  <div class="relative overflow-hidden rounded-t-2xl" style="padding-bottom: 130%;">

    {primaryImg ? (
      <>
        <!-- Primary image -->
        <img
          src={primaryImg}
          alt={name}
          loading="lazy"
          class={`absolute inset-0 w-full h-full object-cover object-top transition-all duration-700 ${hoverImg ? 'group-hover:opacity-0' : ''}`}
        />
        <!-- Hover image (second shot) -->
        {hoverImg && (
          <img
            src={hoverImg}
            alt={`${name} - alternate view`}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover object-top transition-all duration-700 opacity-0 group-hover:opacity-100"
          />
        )}
      </>
    ) : (
      <div class={`absolute inset-0 img-placeholder bg-gradient-to-br ${gradient}`}>
        <div class="text-center px-6 z-10 relative">
          <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-white/30 backdrop-blur-sm flex items-center justify-center">
            <svg width="24" height="24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <p class="text-white/80 text-xs font-body tracking-wide leading-relaxed">Image Coming Soon</p>
        </div>
      </div>
    )}

    <!-- Badge -->
    {badge && (
      <div class="absolute top-3 left-3 z-20">
        <span class="bg-pink-400 text-white text-[10px] font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full shadow-md">
          {badge}
        </span>
      </div>
    )}

    <!-- Wishlist btn -->
    <button
      class="absolute top-3 right-3 z-20 w-8 h-8 bg-white/85 backdrop-blur-sm rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-white hover:scale-110 shadow-sm"
      aria-label={`Add ${name} to wishlist`}
    >
      <svg width="13" height="13" fill="none" stroke="#d4829e" stroke-width="2.2" viewBox="0 0 24 24">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>

    <!-- Quick View overlay -->
    <div class="absolute inset-x-0 bottom-0 z-20 pb-4 flex justify-center opacity-0 group-hover:opacity-100 transition-all duration-300">
      <button class="bg-white/90 backdrop-blur-sm text-stone-800 text-[11px] font-body font-semibold tracking-wider uppercase px-5 py-2.5 rounded-full shadow-lg hover:bg-white transition-colors">
        Quick View
      </button>
    </div>

    <!-- Image dots (if multiple) -->
    {imgList.length > 1 && (
      <div class="absolute bottom-10 left-0 right-0 flex justify-center gap-1 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        {imgList.slice(0, 4).map((_, i) => (
          <div class={`w-1.5 h-1.5 rounded-full ${i === 0 ? 'bg-white' : 'bg-white/50'}`}></div>
        ))}
      </div>
    )}
  </div>

  <!-- Product Info -->
  <div class="p-4 bg-white">
    <p class="text-[10px] text-stone-400 uppercase tracking-widest font-body mb-1">{category}</p>
    <h3 class="font-display text-[15px] font-medium text-stone-800 leading-snug mb-3">{name}</h3>
    <div class="flex items-center justify-between">
      <span class="font-body font-semibold text-pink-500 text-sm tracking-wide">₱{price}</span>
      <button
        class="w-8 h-8 rounded-full bg-pink-50 hover:bg-pink-400 flex items-center justify-center transition-all duration-300 hover:scale-110"
        aria-label={`Add ${name} to cart`}
      >
        <svg class="group-hover:stroke-white" width="14" height="14" fill="none" stroke="#d4829e" stroke-width="2" viewBox="0 0 24 24">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .product-card {
    cursor: pointer;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
  }
  .product-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 20px 44px rgba(0,0,0,0.13);
  }
</style>
