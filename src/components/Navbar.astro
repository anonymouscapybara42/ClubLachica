---
export interface Props {
  activePage?: string;
  transparent?: boolean;
}
const { activePage = '', transparent = false } = Astro.props;

const links = [
  { href: '/about', label: 'About Us' },
  { href: '/catalog', label: 'Catalog' },
  { href: '/collection', label: 'Collection' },
  { href: '/contact', label: 'Contact' },
];
---

<nav
  id="navbar"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${transparent ? 'bg-transparent' : 'bg-cream/90 backdrop-blur-lg shadow-sm'}`}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group">
        <div class="flex flex-col items-start leading-none">
          <span class="font-display text-2xl font-light tracking-[0.15em] text-stone-800 group-hover:text-pink-400 transition-colors duration-300">
            CLUB
          </span>
          <span class="font-display text-lg font-light tracking-[0.35em] text-pink-400 -mt-1">
            LA CHICA
          </span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {links.map(link => (
          <a 
            href={link.href} 
            class={`nav-link ${activePage === link.label.toLowerCase().replace(' ', '') ? 'active' : ''} text-white hover:text-pink-400 transition-colors duration-300`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right icons -->
      <div class="hidden md:flex items-center gap-4">
        <button class={`w-9 h-9 flex items-center justify-center rounded-full transition-all duration-300 hover:bg-pink-100 ${transparent ? 'text-white hover:text-pink-600' : 'text-stone-600 hover:text-pink-600'}`} aria-label="Search">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <button class={`w-9 h-9 flex items-center justify-center rounded-full transition-all duration-300 hover:bg-pink-100 ${transparent ? 'text-white hover:text-pink-600' : 'text-stone-600 hover:text-pink-600'}`} aria-label="Wishlist">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
        <button class={`w-9 h-9 flex items-center justify-center rounded-full transition-all duration-300 hover:bg-pink-100 relative ${transparent ? 'text-white hover:text-pink-600' : 'text-stone-600 hover:text-pink-600'}`} aria-label="Cart">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="absolute -top-1 -right-1 w-4 h-4 bg-pink-400 text-white text-[9px] font-semibold rounded-full flex items-center justify-center">0</span>
        </button>
      </div>

      <!-- Hamburger -->
      <button id="menu-btn" class={`md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 ${transparent ? 'text-white' : 'text-stone-700'}`} aria-label="Open menu">
        <span class="w-6 h-0.5 bg-current block transition-all"></span>
        <span class="w-4 h-0.5 bg-current block transition-all ml-auto"></span>
        <span class="w-6 h-0.5 bg-current block transition-all"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div 
  id="mobile-menu"
  class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500"
>
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="menu-overlay"></div>
  <div class="absolute right-0 top-0 bottom-0 w-80 bg-cream flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-pink-100">
      <div>
        <div class="font-display text-xl font-light tracking-widest text-stone-800">CLUB</div>
        <div class="font-display text-sm font-light tracking-[0.3em] text-pink-400">LA CHICA</div>
      </div>
      <button id="close-menu" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-pink-50 text-stone-600">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <!-- Links -->
    <div class="flex flex-col p-6 gap-2 flex-1">
      {links.map((link, i) => (
        <a 
          href={link.href}
          class="font-display text-2xl font-light text-stone-700 hover:text-pink-400 py-3 border-b border-stone-100 transition-colors duration-300"
          style={`animation-delay: ${i * 0.1}s`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Bottom -->
    <div class="p-6 border-t border-pink-100">
      <p class="text-sm text-stone-500 font-body">Follow us</p>
      <div class="flex gap-4 mt-3">
        <a href="#" class="text-stone-500 hover:text-pink-400 transition-colors" aria-label="Instagram">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
        </a>
        <a href="#" class="text-stone-500 hover:text-pink-400 transition-colors" aria-label="TikTok">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
          </svg>
        </a>
        <a href="#" class="text-stone-500 hover:text-pink-400 transition-colors" aria-label="Facebook">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('menu-overlay')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  });
</script>
