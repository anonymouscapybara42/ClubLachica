---
export interface Props {
  activePage?: string;
  transparent?: boolean;
  user?: import('../lib/db').User | null;
  cartCount?: number;
}
const { activePage = '', transparent = false, user = null, cartCount = 0 } = Astro.props;

const links = [
  { href: '/about', label: 'About Us' },
  { href: '/catalog', label: 'Catalog' },
  { href: '/collection', label: 'Collection' },
  { href: '/contact', label: 'Contact' },
];
---

<nav
  id="navbar"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${transparent ? 'bg-transparent' : 'bg-cream/90 backdrop-blur-lg shadow-sm'}`}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group">
        <div class="flex flex-col items-start leading-none">
          <span class="font-display text-2xl font-light tracking-[0.15em] text-stone-800 group-hover:text-pink-400 transition-colors duration-300">CLUB</span>
          <span class="font-display text-lg font-light tracking-[0.35em] text-pink-400 -mt-1">LA CHICA</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {links.map(link => (
          <a href={link.href}
            class={`nav-link ${activePage === link.label.toLowerCase().replace(' ','') ? 'active' : ''} ${transparent ? 'text-white/90 hover:text-white' : 'text-stone-700 hover:text-stone-900'}`}>
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right Icons -->
      <div class="hidden md:flex items-center gap-3">
        <!-- Cart -->
        <a href="/cart" class={`w-9 h-9 flex items-center justify-center rounded-full transition-all duration-300 hover:bg-pink-100 relative ${transparent ? 'text-white hover:text-pink-600' : 'text-stone-600 hover:text-pink-600'}`} aria-label="Cart">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          {cartCount > 0 && (
            <span class="absolute -top-1 -right-1 w-4 h-4 bg-pink-400 text-white text-[9px] font-semibold rounded-full flex items-center justify-center">{cartCount > 9 ? '9+' : cartCount}</span>
          )}
        </a>

        <!-- User -->
        {user ? (
          <div class="relative group">
            <button class={`flex items-center gap-2 px-3 py-1.5 rounded-full transition-all duration-300 hover:bg-pink-100 ${transparent ? 'text-white hover:text-stone-800' : 'text-stone-600 hover:text-stone-800'}`}>
              <div class="w-7 h-7 rounded-full bg-gradient-to-br from-pink-300 to-rose-200 flex items-center justify-center">
                <span class="font-display text-xs text-stone-700 font-medium">{user.name.charAt(0).toUpperCase()}</span>
              </div>
              <span class="text-xs font-body font-medium hidden lg:block">{user.name.split(' ')[0]}</span>
            </button>
            <!-- Dropdown -->
            <div class="absolute right-0 top-full mt-2 w-48 bg-white rounded-2xl shadow-xl border border-stone-100 overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="px-4 py-3 border-b border-stone-100">
                <p class="font-body font-semibold text-stone-700 text-sm">{user.name}</p>
                <p class="text-stone-400 text-xs font-body truncate">{user.email}</p>
              </div>
              {user.isAdmin && (
                <a href="/admin" class="flex items-center gap-2 px-4 py-2.5 text-sm font-body text-pink-600 hover:bg-pink-50 transition-colors font-semibold">
                  <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  Admin Panel
                </a>
              )}
              <a href="/account" class="flex items-center gap-2 px-4 py-2.5 text-sm font-body text-stone-600 hover:bg-pink-50 transition-colors">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                My Account
              </a>
              <a href="/orders" class="flex items-center gap-2 px-4 py-2.5 text-sm font-body text-stone-600 hover:bg-pink-50 transition-colors">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 0 0-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                My Orders
              </a>
              <a href="/logout" class="flex items-center gap-2 px-4 py-2.5 text-sm font-body text-red-500 hover:bg-red-50 transition-colors border-t border-stone-100">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                Logout
              </a>
            </div>
          </div>
        ) : (
          <a href="/login" class={`nav-link text-sm ${transparent ? 'text-white/90 hover:text-white' : 'text-stone-700'}`}>Sign In</a>
        )}
      </div>

      <!-- Hamburger -->
      <button id="menu-btn" class={`md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 ${transparent ? 'text-white' : 'text-stone-700'}`} aria-label="Open menu">
        <span class="w-6 h-0.5 bg-current block"></span>
        <span class="w-4 h-0.5 bg-current block ml-auto"></span>
        <span class="w-6 h-0.5 bg-current block"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[100] translate-x-full transition-transform duration-500">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="menu-overlay"></div>
  <div class="absolute right-0 top-0 bottom-0 w-80 bg-cream flex flex-col">
    <div class="flex items-center justify-between p-6 border-b border-pink-100">
      <div>
        <div class="font-display text-xl font-light tracking-widest text-stone-800">CLUB</div>
        <div class="font-display text-sm font-light tracking-[0.3em] text-pink-400">LA CHICA</div>
      </div>
      <button id="close-menu" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-pink-50 text-stone-600">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="flex flex-col p-6 gap-1 flex-1 overflow-y-auto">
      {links.map(link => (
        <a href={link.href} class="font-display text-2xl font-light text-stone-700 hover:text-pink-400 py-3 border-b border-stone-100 transition-colors duration-300">{link.label}</a>
      ))}
      <div class="mt-4 pt-4 border-t border-stone-100 space-y-2">
        <a href="/cart" class="flex items-center gap-3 py-2.5 text-stone-600 hover:text-pink-400 transition-colors font-body">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Cart {cartCount > 0 && <span class="ml-1 bg-pink-400 text-white text-[10px] px-2 py-0.5 rounded-full">{cartCount}</span>}
        </a>
        {user ? (
          <>
            {user.isAdmin && <a href="/admin" class="block py-2.5 text-pink-600 font-body font-semibold hover:text-pink-700 transition-colors">Admin Panel</a>}
            <a href="/account" class="block py-2.5 text-stone-600 font-body hover:text-pink-400 transition-colors">My Account</a>
            <a href="/orders" class="block py-2.5 text-stone-600 font-body hover:text-pink-400 transition-colors">My Orders</a>
            <a href="/logout" class="block py-2.5 text-red-500 font-body hover:text-red-600 transition-colors">Logout</a>
          </>
        ) : (
          <>
            <a href="/login" class="block py-2.5 text-stone-600 font-body hover:text-pink-400 transition-colors">Sign In</a>
            <a href="/register" class="block py-2.5 text-pink-500 font-body font-semibold hover:text-pink-600 transition-colors">Create Account</a>
          </>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('menu-overlay')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  });
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  });
  document.getElementById('close-menu')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  });
</script>
