---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us" activePage="contact">
  <Navbar activePage="contact" />

  <!-- Page Header -->
  <div class="pt-28 pb-16 bg-champagne relative overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-pink-200/40 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-60 h-60 bg-sage-200/30 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center relative z-10">
      <p class="text-pink-400 text-xs tracking-[0.3em] uppercase font-body mb-3 animate-on-scroll">We'd Love to Hear From You</p>
      <h1 class="font-display text-5xl lg:text-6xl font-light text-stone-800 mb-4 animate-on-scroll delay-100">Get In Touch</h1>
      <div class="section-divider mt-4 animate-on-scroll delay-200"></div>
      <p class="font-body text-stone-500 mt-6 max-w-md mx-auto animate-on-scroll delay-300">
        Questions, collabs, or just want to say hi? We're always happy to connect with our Club La Chica community.
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- Contact Form -->
        <div class="animate-on-scroll-left">
          <h2 class="font-display text-3xl font-light text-stone-800 mb-2">Send us a message</h2>
          <p class="font-body text-stone-400 text-sm mb-8">We typically reply within 24 hours.</p>

          <form class="space-y-5" onsubmit="return false;">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-body font-medium text-stone-600 tracking-wider uppercase mb-2">First Name</label>
                <input 
                  type="text" 
                  placeholder="Maria"
                  class="w-full bg-cream border border-stone-200 rounded-2xl px-5 py-4 font-body text-stone-700 placeholder-stone-400 focus:outline-none focus:border-pink-300 focus:ring-2 focus:ring-pink-100 transition-all text-sm"
                />
              </div>
              <div>
                <label class="block text-xs font-body font-medium text-stone-600 tracking-wider uppercase mb-2">Last Name</label>
                <input 
                  type="text" 
                  placeholder="Santos"
                  class="w-full bg-cream border border-stone-200 rounded-2xl px-5 py-4 font-body text-stone-700 placeholder-stone-400 focus:outline-none focus:border-pink-300 focus:ring-2 focus:ring-pink-100 transition-all text-sm"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-body font-medium text-stone-600 tracking-wider uppercase mb-2">Email</label>
              <input 
                type="email" 
                placeholder="hello@email.com"
                class="w-full bg-cream border border-stone-200 rounded-2xl px-5 py-4 font-body text-stone-700 placeholder-stone-400 focus:outline-none focus:border-pink-300 focus:ring-2 focus:ring-pink-100 transition-all text-sm"
              />
            </div>

            <div>
              <label class="block text-xs font-body font-medium text-stone-600 tracking-wider uppercase mb-2">Subject</label>
              <select class="w-full bg-cream border border-stone-200 rounded-2xl px-5 py-4 font-body text-stone-700 focus:outline-none focus:border-pink-300 focus:ring-2 focus:ring-pink-100 transition-all text-sm cursor-pointer">
                <option value="" disabled selected>Select a topic</option>
                <option>Order Inquiry</option>
                <option>Returns & Exchanges</option>
                <option>Collaboration / Influencer</option>
                <option>Wholesale</option>
                <option>General Question</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-body font-medium text-stone-600 tracking-wider uppercase mb-2">Message</label>
              <textarea 
                rows="5"
                placeholder="Tell us how we can help..."
                class="w-full bg-cream border border-stone-200 rounded-2xl px-5 py-4 font-body text-stone-700 placeholder-stone-400 focus:outline-none focus:border-pink-300 focus:ring-2 focus:ring-pink-100 transition-all resize-none text-sm"
              ></textarea>
            </div>

            <button type="submit" class="w-full btn-primary py-4 text-center rounded-2xl">
              Send Message →
            </button>
          </form>
        </div>

        <!-- Info Panel -->
        <div class="animate-on-scroll-right space-y-8">
          
          <!-- Contact Cards -->
          <div>
            <h2 class="font-display text-3xl font-light text-stone-800 mb-6">Our Details</h2>
            <div class="space-y-4">
              {[
                { icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0zM12 10a2 2 0 1 1 0-4 2 2 0 0 1 0 4z', label: 'Visit Us', value: 'Bacolod City, Philippines', sub: 'By appointment only' },
                { icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z', label: 'Call Us', value: '+63 917 123 4567', sub: 'Mon–Sat, 9AM–6PM' },
                { icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 6l-10 7L2 6', label: 'Email Us', value: 'hello@clublachica.ph', sub: 'We reply within 24 hours' },
              ].map(item => (
                <div class="flex gap-4 items-start bg-cream rounded-2xl p-5">
                  <div class="w-11 h-11 rounded-xl bg-pink-100 flex items-center justify-center flex-shrink-0">
                    <svg width="18" height="18" fill="none" stroke="#d4829e" stroke-width="1.8" viewBox="0 0 24 24">
                      <path d={item.icon}/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-stone-400 uppercase tracking-widest font-body">{item.label}</p>
                    <p class="font-body font-medium text-stone-700 mt-0.5 text-sm">{item.value}</p>
                    <p class="text-stone-400 text-xs mt-0.5">{item.sub}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Hours -->
          <div class="bg-cream rounded-3xl p-8">
            <h3 class="font-display text-xl font-medium text-stone-800 mb-5">Business Hours</h3>
            <div class="space-y-3">
              {[
                { day: 'Monday – Friday', hours: '9:00 AM – 6:00 PM' },
                { day: 'Saturday', hours: '10:00 AM – 5:00 PM' },
                { day: 'Sunday', hours: 'Closed' },
              ].map(h => (
                <div class="flex justify-between items-center py-2 border-b border-stone-200 last:border-0">
                  <span class="font-body text-stone-600 text-sm">{h.day}</span>
                  <span class={`font-body text-sm font-medium ${h.hours === 'Closed' ? 'text-stone-400' : 'text-pink-500'}`}>{h.hours}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Social -->
          <div>
            <h3 class="font-display text-xl font-medium text-stone-800 mb-4">Follow the Club</h3>
            <div class="flex gap-3">
              {[
                { name: 'Instagram', handle: '@clublachica', icon: 'M2 2h20v20H2zM12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm5.5-2a1 1 0 1 0 0 2 1 1 0 0 0 0-2z', bg: 'bg-gradient-to-br from-pink-400 to-rose-500' },
                { name: 'TikTok', handle: '@clublachica', icon: 'M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5', bg: 'bg-stone-900' },
                { name: 'Facebook', handle: 'Club La Chica', icon: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z', bg: 'bg-blue-600' },
              ].map(social => (
                <a href="#" class="flex-1 flex flex-col items-center p-4 rounded-2xl border border-stone-200 hover:border-pink-200 hover:shadow-md transition-all duration-300 group">
                  <div class={`w-10 h-10 rounded-full ${social.bg} flex items-center justify-center mb-2`}>
                    <svg width="16" height="16" fill="none" stroke="white" stroke-width="1.8" viewBox="0 0 24 24">
                      <path d={social.icon}/>
                    </svg>
                  </div>
                  <p class="font-body font-semibold text-stone-700 text-xs">{social.name}</p>
                  <p class="text-stone-400 text-[10px] mt-0.5">{social.handle}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="bg-cream py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="rounded-3xl overflow-hidden bg-gradient-to-br from-sage-100 to-green-50 h-72 flex flex-col items-center justify-center shadow-inner border border-sage-200">
        <div class="w-16 h-16 rounded-full bg-pink-100 flex items-center justify-center mb-4">
          <svg width="28" height="28" fill="none" stroke="#d4829e" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-light text-stone-600 mb-1">Map Coming Soon</h3>
        <p class="font-body text-stone-400 text-sm text-center max-w-xs">
          Our physical location will be announced soon. Stay tuned on Instagram!
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Teaser -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center animate-on-scroll">
      <h2 class="font-display text-3xl font-light text-stone-800 mb-4">Frequently Asked Questions</h2>
      <p class="font-body text-stone-500 leading-relaxed mb-8">Looking for quick answers? Check out our FAQ section for shipping info, sizing, returns, and more.</p>
      <a href="#" class="btn-outline">View FAQs</a>
    </div>
  </section>

  <Footer />
</Layout>
