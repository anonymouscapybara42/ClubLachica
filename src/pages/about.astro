---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getSessionUser, getCart } from '../lib/auth';
const user = getSessionUser(Astro.request);
const cartCount = getCart(Astro.request).reduce((s, i) => s + i.qty, 0);


const values = [
  { icon: '🌸', title: 'Feminine First', desc: 'Every piece is designed to celebrate womanhood in all its forms — soft, bold, playful, and powerful.' },
  { icon: '✨', title: 'Quality Crafted', desc: 'We source premium fabrics and work with skilled makers to bring you pieces that look and feel luxurious.' },
  { icon: '💚', title: 'Mindfully Made', desc: 'We are committed to reducing our footprint through thoughtful sourcing, minimal packaging, and ethical production.' },
  { icon: '🇵🇭', title: 'Proudly Filipino', desc: 'Club La Chica is built and rooted in the Philippines — celebrating the vibrant style of the modern Filipina.' },
];

const team = [
  { name: 'Fiona Acero', role: 'Co- Founder', gradient: 'from-pink-200 to-rose-100' },
  { name: 'Arianna Antay', role: 'Co-Founder', gradient: 'from-sage-200 to-green-100' },
  { name: 'Mia Torres', role: 'Marketer', gradient: 'from-amber-100 to-orange-100' },
];
---

<Layout title="About Us" activePage="about">
  <Navbar activePage="about" transparent={true} user={user} cartCount={cartCount} />

  <!-- Hero -->
  <div class="relative min-h-[75vh] flex items-center overflow-hidden bg-champagne">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-1/2 h-full img-placeholder bg-gradient-to-bl from-pink-200 via-rose-100 to-transparent opacity-70"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-sage-200/40 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-24">
      <div class="max-w-2xl">
        <p class="text-pink-400 text-xs tracking-[0.4em] uppercase font-body mb-6 animate-on-scroll">Who We Are</p>
        <h1 class="font-display text-6xl lg:text-7xl font-light text-stone-800 leading-none mb-8 animate-on-scroll delay-100">
          A Brand<br/>Built With<br/><span class="italic text-pink-400">Love & Style</span>
        </h1>
        <p class="font-body text-stone-500 text-lg leading-relaxed animate-on-scroll delay-200">
          Club La Chica is a Filipino fashion label created for women who love fashion, value quality, and want to look effortlessly beautiful every day.
        </p>
      </div>
    </div>
  </div>

  <!-- Our Story -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        
        <!-- Images -->
        <div class="grid grid-cols-2 gap-4 animate-on-scroll-left">
          <div class="aspect-[3/4] rounded-3xl overflow-hidden img-placeholder bg-gradient-to-br from-pink-200 via-rose-100 to-champagne shadow-xl">
            <div class="flex flex-col items-center justify-center h-full text-center px-6 relative z-10">
              <p class="text-white/70 font-display text-lg font-light">Founding Story</p>
              <p class="text-white/50 text-xs font-body mt-2">Photo Coming Soon</p>
            </div>
          </div>
          <div class="space-y-4 mt-10">
            <div class="aspect-square rounded-3xl overflow-hidden img-placeholder bg-gradient-to-br from-sage-200 to-green-100 shadow-xl">
              <div class="flex flex-col items-center justify-center h-full text-center px-4 relative z-10">
                <p class="text-white/70 text-xs font-body">Atelier</p>
              </div>
            </div>
            <div class="aspect-[4/3] rounded-3xl overflow-hidden img-placeholder bg-gradient-to-br from-amber-100 to-orange-100 shadow-xl">
              <div class="flex flex-col items-center justify-center h-full text-center px-4 relative z-10">
                <p class="text-stone-500/70 text-xs font-body">Our Team</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="animate-on-scroll-right">
          <p class="text-pink-400 text-xs tracking-[0.3em] uppercase font-body mb-4">The Beginning</p>
          <h2 class="font-display text-4xl lg:text-5xl font-light text-stone-800 mb-6">How We Started</h2>
          <div class="w-12 h-px bg-gradient-to-r from-pink-300 to-sage-300 mb-8"></div>
          
          <div class="space-y-5 font-body text-stone-500 leading-relaxed">
            <p>
              Club Lachica is a local brand founded by Fiona and Ariana, later joined by Nika. The brand creates clothing designed for teens and women, building a community where individuals can freely express their personal style and love for fashion.</p>
            <p>
           Beyond clothing, Club Lachica also supports local women seamstresses around Negros Occidental, helping create more opportunities for locals to earn and showcase their craftsmanship.</p>
         
          </div>

          <!-- Timeline -->
          <div class="mt-10 space-y-4">
            {[
              { year: '2020', event: 'Founded with our first drop of 12 pieces' },
              { year: '2022', event: 'Reached 50,000 happy customers' },
              { year: '2023', event: 'Launched our first flagship collection' },
              { year: '2025', event: 'Now 500+ styles & still growing' },
            ].map(item => (
              <div class="flex gap-4 items-start">
                <span class="font-display text-pink-400 font-medium flex-shrink-0 w-12">{item.year}</span>
                <div class="flex-1">
                  <div class="w-full h-px bg-stone-100 mb-3 relative">
                    <div class="absolute left-0 -top-1 w-2 h-2 rounded-full bg-pink-300"></div>
                  </div>
                  <p class="text-stone-500 text-sm">{item.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-20 bg-stone-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-pink-400/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-pink-400 text-xs tracking-[0.3em] uppercase font-body mb-3 animate-on-scroll">What Drives Us</p>
        <h2 class="font-display text-4xl lg:text-5xl font-light text-white animate-on-scroll delay-100">Mission & Vision</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-10 animate-on-scroll">
          <div class="w-12 h-12 rounded-2xl bg-pink-400/20 flex items-center justify-center mb-6">
            <svg width="24" height="24" fill="none" stroke="#f9a8d4" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3 class="font-display text-2xl font-light text-white mb-4">Our Mission</h3>
          <p class="font-body text-stone-400 leading-relaxed">
            To empower every Filipina to dress with confidence and joy — offering thoughtfully curated fashion that is accessible, beautiful, and made with genuine care for the woman who wears it.
          </p>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-10 animate-on-scroll delay-200">
          <div class="w-12 h-12 rounded-2xl bg-sage-400/20 flex items-center justify-center mb-6">
            <svg width="24" height="24" fill="none" stroke="#a6bfa6" stroke-width="1.8" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3 class="font-display text-2xl font-light text-white mb-4">Our Vision</h3>
          <p class="font-body text-stone-400 leading-relaxed">
            To become the most loved women's fashion brand in Southeast Asia — a brand that women trust, celebrate, and grow with. A brand that proves that style and substance can coexist beautifully.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-pink-400 text-xs tracking-[0.3em] uppercase font-body mb-3 animate-on-scroll">What We Stand For</p>
        <h2 class="font-display text-4xl lg:text-5xl font-light text-stone-800 animate-on-scroll delay-100">Our Values</h2>
        <div class="section-divider mt-4 animate-on-scroll delay-200"></div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((val, i) => (
          <div class={`bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 animate-on-scroll`} style={`transition-delay: ${i*0.1}s`}>
            <span class="text-4xl block mb-5">{val.icon}</span>
            <h3 class="font-display text-xl font-medium text-stone-800 mb-3">{val.title}</h3>
            <p class="font-body text-stone-500 text-sm leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-pink-400 text-xs tracking-[0.3em] uppercase font-body mb-3 animate-on-scroll">The People Behind CLC</p>
        <h2 class="font-display text-4xl lg:text-5xl font-light text-stone-800 animate-on-scroll delay-100">Meet The Team</h2>
        <div class="section-divider mt-4 animate-on-scroll delay-200"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-3xl mx-auto">
        {team.map((member, i) => (
          <div class={`text-center animate-on-scroll`} style={`transition-delay: ${i*0.15}s`}>
            <div class={`w-48 h-48 mx-auto rounded-full overflow-hidden img-placeholder bg-gradient-to-br ${member.gradient} shadow-xl mb-6`}>
              <div class="flex flex-col items-center justify-center h-full text-center px-6 relative z-10">
                <svg width="28" height="28" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="1.5" viewBox="0 0 24 24">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                <p class="text-white/60 text-[10px] font-body mt-2">Photo Soon</p>
              </div>
            </div>
            <h3 class="font-display text-xl font-medium text-stone-800">{member.name}</h3>
            <p class="text-stone-400 text-sm font-body mt-1">{member.role}</p>
            <div class="flex gap-3 justify-center mt-4">
              <a href="#" class="w-8 h-8 rounded-full border border-stone-200 flex items-center justify-center hover:border-pink-300 hover:text-pink-400 transition-all text-stone-400">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
                </svg>
              </a>
              <a href="#" class="w-8 h-8 rounded-full border border-stone-200 flex items-center justify-center hover:border-pink-300 hover:text-pink-400 transition-all text-stone-400">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-pink-100 via-rose-50 to-champagne">
    <div class="max-w-2xl mx-auto text-center px-6 animate-on-scroll">
      <h2 class="font-display text-4xl font-light text-stone-800 mb-4">Join the Club</h2>
      <p class="font-body text-stone-500 leading-relaxed mb-8">Become part of a community of stylish women who celebrate each other every day.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/catalog" class="btn-primary">Shop Now</a>
        <a href="/contact" class="btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
