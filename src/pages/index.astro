  {
    name: 'Fifi Set',
    price: '1,750',
    category: 'Sets',
    badge: 'Best Seller',
    images: [
      '/images/products/fifi/184A1212.jpeg',
      '/images/products/fifi/184A1220.jpeg',
    ],
  },
  {
