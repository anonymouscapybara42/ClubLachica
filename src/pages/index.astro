    price: '1,750',
    category: 'Sets',
    badge: 'Popular',
    images: [
      '/images/products/lachica/IMG_9103.jpeg',
      '/images/products/lachica/IMG_9145.jpeg',
    ],
  },
  {
    name: 'Ari Top',
    price: '850',
    category: 'Tops',
    images: [
